{
  "name": "swiz",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "swiz": "index.ts"
  },
  "scripts": {
    "start": "bun run index.ts",
    "test": "bun test --concurrent --timeout=10000",
    "test:vitest": "vitest",
    "test:bun": "bun test --concurrent --timeout=10000",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . && eslint .",
    "lint:eslint": "eslint .",
    "format": "biome format --write .",
    "lint:fix": "biome check --write . && eslint . --fix && biome format --write .",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "ai": "^6.0.116",
    "ai-sdk-provider-claude-code": "^3.4.3",
    "ai-sdk-provider-codex-cli": "^1.1.0",
    "ai-sdk-provider-gemini-cli": "^2.0.1",
    "date-fns": "^4.1.0",
    "lodash-es": "^4.17.23",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ufo": "^1.6.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "latest",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "lefthook": "^2.1.1",
    "lint-staged": "^16.2.7",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
