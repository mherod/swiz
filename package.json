    "lru-cache": "^11.2.6",
    "motion": "^12.36.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "ufo": "^1.6.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
