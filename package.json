    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "bun-plugin-tailwind": "^0.1.2",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "lefthook": "^2.1.1",
    "lint-staged": "^16.2.7",
    "typescript-eslint": "^8.57.0",
